# Firebase クライアント設定（公開可能なクライアント値のみ／シークレットではない）
# 実際の .env（gitignore 済み）にコピーして値を入れると isFirebaseConfigured=true になり、
# 認証がローカル匿名 → Firebase 匿名認証へ自動で切り替わる（src/services/firebase/config.ts）。
# 値は Firebase Console → プロジェクト設定 → 「マイアプリ（ウェブ）」の firebaseConfig から取得。
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# AI 連携プロキシ（Cloudflare Worker）の URL。
# Firebase Blaze プランを使わず Spark プランを維持するため、Firebase Functions ではなく
# Cloudflare Workers（worker/）を経由して AI（現在の実装は Google Gemini API。
# 詳細は worker/README.md 参照）を呼ぶ（environments.md）。
# 未設定の場合は診断系（連想語提案・日記文生成・調整・AI対話）がモック実装で動作する。
# 値は `wrangler deploy` 実行後に払い出される Worker の URL（例: https://tasogare-diary-claude-proxy.<subdomain>.workers.dev）。
EXPO_PUBLIC_CLAUDE_WORKER_URL=

# Web ダッシュボードの URL（QRペアリングのディープリンク生成に使用。任意）。
# 設定時、QR に `<URL>/pair?token=...` を埋め込む。未設定ならトークン文字列のみを QR 化する。
EXPO_PUBLIC_WEB_URL=

# ネイティブ資格情報取得（Apple/Google サインインUI）の有効化スイッチ（開発/配布ビルドのみ）。
# '1' または 'true' で、起動時に installNativeCredentialSource() を呼ぶ配線が有効になる
# （index.ts → nativeAuthBootstrap）。**Expo Go では設定しないこと**: ネイティブモジュール
# （expo-apple-authentication / @react-native-google-signin）を評価して起動が壊れるため。
# 未設定（既定）なら bootstrap は何もせず canLinkAccount は false で導線非表示（environments.md）。
EXPO_PUBLIC_ENABLE_NATIVE_AUTH=

# Apple サインイン（匿名→恒久アカウント昇格）の有効化スイッチ（開発/配布ビルドのみ・既定は無効）。
# '1' または 'true' で app.config.ts が ios.usesAppleSignIn・expo-apple-authentication プラグインを
# 含め、entitlement（com.apple.developer.applesignin）を付与する。**有料 Apple Developer Program が
# 必須**（無料の Personal Team だとこの entitlement 付きの provisioning profile を作成できずビルドが
# 失敗する）。未加入の間は未設定のままにすること（この場合 app.config.ts が entitlement を明示的に
# 除去し、nativeCredentialSourceInstall.ts も同じフラグで Apple を利用不可にする＝ボタン自体を出さない）。
# ローカル `.env` は Node 実行時（app.config.ts の prebuild 評価）には読み込まれるが、EAS Build
# （クラウドビルド）ではリポジトリの `.env` はアップロードされないため、EAS 側では `eas.json` の
# env またはプロジェクトの Environment Variables（Secrets）に別途同名で設定する必要がある。
EXPO_PUBLIC_APPLE_SIGNIN_ENABLED=

# ネイティブ Google サインイン（匿名→恒久アカウント昇格）の webClientId（任意・開発ビルドのみ）。
# Firebase 用 idToken を得るため必須。Firebase Console → Authentication → Google を有効化した際に
# 作られる「ウェブ クライアント（自動作成）」の OAuth 2.0 クライアント ID を設定する。
# 未設定なら Google サインインは利用不可（canLinkAccount('google') が false で導線非表示）。
# 有効化には開発ビルドでの installNativeCredentialSource() 呼び出しが必要（Expo Go では未適用）。
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ネイティブ Google サインインの iOS クライアントID（iOS 開発ビルドでは必須。Android では不要）。
# GoogleService-Info.plist を使わない構成のため、iOS では webClientId だけでなくこの値も
# GoogleSignin.configure() に iosClientId として明示的に渡す必要がある（nativeCredentialSourceInstall.ts）。
# 未設定のまま iOS で Google サインインを試すと「RNGoogleSignin: failed to determine clientID」で
# クラッシュする（実機検証で確認）。値は Firebase Console → プロジェクト設定 →「マイアプリ」に
# **iOS アプリ**（bundleId: app.tasogarediary）を追加した際に作られる iOS 用 OAuth クライアントの
# 「クライアント ID」（例: 1234567890-abcdefg.apps.googleusercontent.com。下記 URL_SCHEME とは別物、
# 逆順になっていない方の値）。
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# ネイティブ Google サインインの iOS 逆順クライアントID（iOS 開発ビルドでは必須。Android では不要）。
# iOS はサインインのリダイレクト受け取りに CFBundleURLSchemes への登録が必要。設定すると
# app.config.ts が @react-native-google-signin の config plugin に iosUrlScheme として渡す。
# 値は上記 EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID と同じ iOS 用 OAuth クライアントの「逆順クライアントID」
# （例: com.googleusercontent.apps.1234567890-abcdefg）。
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

# ネイティブ Firebase（@react-native-firebase）への移行スイッチ（開発/配布ビルドのみ・既定は無効）。
# '1' または 'true' で app.config.ts が @react-native-firebase/app（+ auth）の config plugin と
# 下記 googleServicesFile を有効化し、認証・Firestore アクセスがネイティブ SDK 経路に切り替わる
# （Firestore のオフライン永続キューを得るための移行。docs/migration-react-native-firebase.md）。
# **Expo Go では設定しないこと**（ネイティブモジュールを評価して起動が壊れるため）。未設定（既定）なら
# 現行の Firebase JS SDK 経路のまま。有効化には後続フェーズ（nativeFirebaseAuthProvider 等）の実装と
# 開発ビルドが必要。iOS の useFrameworks:'static' との併用は実機ビルドで要確認（第9章）。
EXPO_PUBLIC_USE_NATIVE_FIREBASE=

# ネイティブ設定ファイルの配置パス（任意・上記フラグ有効時のみ使用）。未設定ならリポジトリルート直下の
# ./GoogleService-Info.plist（iOS）/ ./google-services.json（Android）を参照する。いずれも Firebase
# Console → プロジェクト設定 → iOS/Android アプリを追加 でダウンロードする公開可能な設定ファイル。
# ただし環境ごと（dev/staging/prod）に別ファイルのため **リポジトリにはコミットしない**（.gitignore 済み）。
# 環境別に配置を切り替える場合はこのパスを APP_ENV に応じて差し替える運用にできる（切り替え方式の
# 最終決定は docs/migration-react-native-firebase.md 第9章の未決事項）。
EXPO_PUBLIC_GOOGLE_SERVICES_PLIST=
EXPO_PUBLIC_GOOGLE_SERVICES_JSON=

# Firebase の **iOS アプリ**（上記とは別。EXPO_PUBLIC_FIREBASE_APP_ID は Web アプリの App ID）の
# App ID（GOOGLE_APP_ID。形式 "1:PROJECT_NUMBER:ios:HASH"）。@react-native-google-signin の新しい
# iOS SDK（AppCheck連携）が、この値から派生する URL scheme（":" を "-" に置換し "app-" を付けた形。
# 例: "app-1-1234567890-ios-abcdef1234567890"）の登録も別途要求する。未設定のまま iOS で Google
# サインインを試すと「Your app is missing support for the following URL schemes: app-1-...」で
# 失敗する（実機検証で確認）。値は Firebase Console → プロジェクト設定 → 一般 →「マイアプリ」の
# **iOS アプリ**の行にある「アプリID」（Web アプリの行の値ではない）。
EXPO_PUBLIC_FIREBASE_IOS_APP_ID=
