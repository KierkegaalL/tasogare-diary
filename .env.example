# Firebase クライアント設定（公開可能なクライアント値のみ／シークレットではない）
# 実際の .env（gitignore 済み）にコピーして値を入れると isFirebaseConfigured=true になり、
# 認証がローカル匿名 → Firebase 匿名認証へ自動で切り替わる（src/services/firebase/config.ts）。
# 値は Firebase Console → プロジェクト設定 → 「マイアプリ（ウェブ）」の firebaseConfig から取得。
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# AI 連携プロキシ（Cloudflare Worker）の URL。
# Firebase Blaze プランを使わず Spark プランを維持するため、Firebase Functions ではなく
# Cloudflare Workers（worker/）を経由して AI（現在の実装は Google Gemini API。
# 詳細は worker/README.md 参照）を呼ぶ（environments.md）。
# 未設定の場合は診断系（連想語提案・日記文生成・調整・AI対話）がモック実装で動作する。
# 値は `wrangler deploy` 実行後に払い出される Worker の URL（例: https://tasogare-diary-claude-proxy.<subdomain>.workers.dev）。
EXPO_PUBLIC_CLAUDE_WORKER_URL=
