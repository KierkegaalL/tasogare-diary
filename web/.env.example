# Web ダッシュボードの環境変数（公開可能なクライアント値のみ／シークレットではない）。
# 実際の .env.local（gitignore 済み）にコピーして値を入れる。
# Firebase の値はモバイルと同一プロジェクトのものを使う（同じ Firestore を参照するため）。

# Firebase クライアント設定（src/lib/firebase.ts）。
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# AI 連携プロキシ（Cloudflare Worker）の URL。QRペアリング照合・まとめ生成に使う。
# 値は `wrangler deploy` 実行後に払い出される Worker の URL（モバイルの EXPO_PUBLIC_CLAUDE_WORKER_URL と同一）。
NEXT_PUBLIC_WORKER_URL=
